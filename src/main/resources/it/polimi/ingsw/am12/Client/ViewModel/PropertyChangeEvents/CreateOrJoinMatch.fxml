<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Text?>
<VBox fx:id="root" alignment="TOP_CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.polimi.ingsw.am12.Client.UI.Gui.ControllerCreateOrJoinMatch">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <HBox>
        <Text fx:id="errorMessage" stroke="crimson"/>
        <Button fx:id="closeErrorMessage" onAction="#closeErrorMessage" visible="false">Close</Button>
    </HBox>
    <HBox alignment="CENTER" spacing="20.0">
        <Button text="Create match" onAction="#onCreateMatchClick"/>
        <Button text="Join match" onAction="#onJoinMatchClick"/>
        <Button text="Get lobbies" onAction="#onGetLobbiesClick"/>
    </HBox>
    <VBox fx:id="content" alignment="TOP_CENTER" spacing="20.0">

    </VBox>
</VBox>