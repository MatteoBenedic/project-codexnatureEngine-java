<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.text.Text?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      stylesheets="/css/style.css"
      styleClass="background"
      fx:controller="it.polimi.ingsw.am12.Client.UI.Gui.ControllerLobby">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <HBox alignment="CENTER">
        <Text fx:id="errorMessage" stroke="crimson"/>
        <Button fx:id="closeErrorMessage" onAction="#closeErrorMessage" visible="false">Close</Button>
    </HBox>
    <Text text="Lobby" styleClass="title"/>
    <HBox alignment="CENTER" spacing="20.0" fx:id = "lobbies">
    </HBox>
    <Button fx:id= "startMatchButton" text="Start match" onAction="#onStartMatchClick" visible="false"/>
</VBox>
