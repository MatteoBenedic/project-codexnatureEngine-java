    void addPlayersToMatch(nicknames : List<String>)
    void placeStartCards(selectedSides : Map<String, Boolean>)
    void setPlayerColors(selectedColors : Map<String, PlayerColor>)
    void distributeCards()
    void setPlayerObjectives(selectedObjectives : Map<String, Boolean>)
